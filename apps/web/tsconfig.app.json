{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@mcp-definer/schemas": ["../../packages/schemas/src/index.ts"],
      "@mcp-definer/generator": ["../../packages/generator/src/index.ts"],
      "@mcp-definer/auth": ["../../packages/auth/src/index.ts"]
    }
  },
  "include": ["src"]
}
