    "@mcp-definer/schemas": "workspace:*",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  }
