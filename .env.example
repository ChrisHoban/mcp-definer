# Copy this file to `.env` at the repo root (gitignored):
#   cp .env.example .env   (Unix)  |  copy .env.example .env   (Windows)
#
# All services read from this file. Production requires explicit values (no dev fallbacks).

# --- Database (local Docker Postgres) ---
DATABASE_URL=postgresql://mcp_definer:mcp_definer@localhost:5432/mcp_definer

# Used by docker/docker-compose.yml when present (must match DATABASE_URL credentials)
PGHOST=localhost
PGPORT=5432
PGUSER=mcp_definer
PGPASSWORD=mcp_definer
PGDATABASE=mcp_definer

# --- Control plane API ---
API_PORT=3000
MCP_DEFINER_API_KEY=dev-api-key

# Registry store backend (default: postgres). Unit tests use memory via VITEST=true.
REGISTRY_STORE=postgres
RUN_MIGRATIONS_ON_STARTUP=true
MOCK_MODE=true

# Public base URL for discovery links (optional; defaults to http://localhost:${API_PORT}/v1)
# API_PUBLIC_URL=http://localhost:3000/v1

# --- Web UI (Vite reads VITE_* from this file via apps/web/vite.config.ts) ---
WEB_PORT=5173
VITE_API_URL=/v1
VITE_API_KEY=dev-api-key

NODE_ENV=development

# Remote OpenAPI URL import (ADR-014) — comma-separated host allow-list; required for POST /specs/parse { "url": "..." }
# SPEC_FETCH_ALLOWLIST=raw.githubusercontent.com,petstore.swagger.io

# Credential secrets: set per binding at deploy time (ADR-013), e.g. MCP_DEFINER_SECRET_cb_petstore_apikey=your-key
